# Dependencies
node_modules/

# Build artifacts
dist/
*.tsbuildinfo

# Test and coverage outputs
coverage
playwright-report
test-results/

# OS and editor files
.DS_Store
.idea
.vscode/

# Environment and local runtime artifacts
.env
.env.*
*.log

