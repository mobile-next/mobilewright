packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map
packages/*/templates/**/*.js
packages/*/templates/**/*.js.map
packages/*/templates/**/*.d.ts
packages/*/templates/**/*.d.ts.map
e2e/**/*.js
e2e/**/*.js.map
e2e/**/*.d.ts
e2e/**/*.d.ts.map
scripts/**/*.js
scripts/**/*.js.map
scripts/**/*.d.ts
scripts/**/*.d.ts.map
tests/**/*.js
tests/**/*.js.map
tests/**/*.d.ts
tests/**/*.d.ts.map
examples/**/*.js
